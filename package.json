{
  "name": "ldac-profile",
  "version": "0.1.0",
  "description": "LDAC Profile to validate an RO-Crate",
  "main": "make-profile.js",
  "scripts": {
    "test": "mocha",
    "build-spec": "node make-profile.js",
    "build:profile": "generate-masp-docs masp-profile/profile-crate/ro-crate-metadata.json masp-profile/profile-text.md masp-profile/profile-crate/profile-documentation.md",
    "build:schema": "generate-masp-docs masp-schema/schema-crate/ro-crate-metadata.json masp-schema/schema-text.md masp-schema/schema-crate/schema-documentation.md",
    "build:mode": "generate-mode-file --output masp-profile/profile-crate/crate-o-mode.json --update-profile masp-profile/profile-crate/ro-crate-metadata.json"
  },
  "repository": {
    "type": "git",
    "url": "github"
  },
  "keywords": [
    "rocrate",
    "validator"
  ],
  "author": "Alvin Sebastian (https://orcid.org/0000-0002-9086-1722)",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "mocha": "^10.0.0"
  },
  "dependencies": {
    "ro-crate-masp": "github:Language-Research-Technology/ro-crate-masp"
  }
}